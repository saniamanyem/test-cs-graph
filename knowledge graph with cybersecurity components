        ></script>


        <center>
          <h1></h1>
        </center>
        <style type="text/css">

             #mynetwork {
                 width: 100%;
                 height: 750px;
                 background-color: #ffffff;
                 border: 1px solid lightgray;
                 position: relative;
                 float: left;
             }

             

             
             #config {
                 float: left;
                 width: 400px;
                 height: 600px;
             }
             

             
        </style>
    </head>


    <body>
        <div class="card" style="width: 100%">
            
            
            <div id="mynetwork" class="card-body"></div>
        </div>

        
        
            <div id="config"></div>
        

        <script type="text/javascript">

              // initialize global variables.
              var edges;
              var nodes;
              var allNodes;
              var allEdges;
              var nodeColors;
              var originalNodes;
              var network;
              var container;
              var options, data;
              var filter = {
                  item : '',
                  property : '',
                  value : []
              };

              

              

                            // This method is responsible for drawing the graph, returns the drawn network
                            function drawGraph() {
                  var container = document.getElementById('mynetwork');

                                    // Embedded graph data (converted from cybersecurity_relationships.csv)
                                    nodes = new vis.DataSet([
                                        {"id":"AccessControl","label":"AccessControl","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"Alarm","label":"Alarm","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"Applications","label":"Applications","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"BackupPower","label":"BackupPower","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"Building","label":"Building","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"CCTV","label":"CCTV","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"Communications","label":"Communications","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"Dispatch","label":"Dispatch","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"EMS","label":"EMS","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"Evacuation","label":"Evacuation","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"FirstResponder","label":"FirstResponder","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"Fire","label":"Fire","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"FireAlarm","label":"FireAlarm","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"FireTruck","label":"FireTruck","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"Hydrant","label":"Hydrant","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"HVAC","label":"HVAC","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"ITSystems","label":"ITSystems","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"ITSystemsDown","label":"ITSystemsDown","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"IncidentCommander","label":"IncidentCommander","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"MedicalInjury","label":"MedicalInjury","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"Occupants","label":"Occupants","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"PowerFailure","label":"PowerFailure","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"PowerSystem","label":"PowerSystem","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"Radio","label":"Radio","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"Servers","label":"Servers","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"Smoke","label":"Smoke","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"SmokeDetector","label":"SmokeDetector","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"SprinklerSystem","label":"SprinklerSystem","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"VideoEvidence","label":"VideoEvidence","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"Workstations","label":"Workstations","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"Water","label":"Water","shape":"dot","size":10,"color":"#97c2fc"},
                                        {"id":"Entry","label":"Entry","shape":"dot","size":10,"color":"#97c2fc"}
                                    ]);
                                    edges = new vis.DataSet([
                                        {"arrows":"to","from":"Building","label":"Contains","to":"ITSystems","width":1},
                                        {"arrows":"to","from":"Building","label":"Contains","to":"FireAlarm","width":1},
                                        {"arrows":"to","from":"Building","label":"Contains","to":"HVAC","width":1},
                                        {"arrows":"to","from":"Building","label":"Contains","to":"SprinklerSystem","width":1},
                                        {"arrows":"to","from":"Building","label":"Contains","to":"PowerSystem","width":1},
                                        {"arrows":"to","from":"ITSystems","label":"Includes","to":"Servers","width":1},
                                        {"arrows":"to","from":"ITSystems","label":"Includes","to":"Workstations","width":1},
                                        {"arrows":"to","from":"Servers","label":"Hosts","to":"Applications","width":1},
                                        {"arrows":"to","from":"Servers","label":"DependsOn","to":"PowerSystem","width":1},
                                        {"arrows":"to","from":"PowerSystem","label":"Feeds","to":"ITSystems","width":1},
                                        {"arrows":"to","from":"Fire","label":"OccursIn","to":"Building","width":1},
                                        {"arrows":"to","from":"Fire","label":"Triggers","to":"FireAlarm","width":1},
                                        {"arrows":"to","from":"Fire","label":"Produces","to":"Smoke","width":1},
                                        {"arrows":"to","from":"Smoke","label":"DetectedBy","to":"SmokeDetector","width":1},
                                        {"arrows":"to","from":"SmokeDetector","label":"Notifies","to":"FireAlarm","width":1},
                                        {"arrows":"to","from":"FireAlarm","label":"Alerts","to":"Occupants","width":1},
                                        {"arrows":"to","from":"FireAlarm","label":"Alerts","to":"FirstResponder","width":1},
                                        {"arrows":"to","from":"SprinklerSystem","label":"Suppresses","to":"Fire","width":1},
                                        {"arrows":"to","from":"HVAC","label":"Spreads","to":"Smoke","width":1},
                                        {"arrows":"to","from":"FirstResponder","label":"RespondsTo","to":"Fire","width":1},
                                        {"arrows":"to","from":"FirstResponder","label":"Enters","to":"Building","width":1},
                                        {"arrows":"to","from":"FirstResponder","label":"Uses","to":"Radio","width":1},
                                        {"arrows":"to","from":"FirstResponder","label":"CommunicatesWith","to":"Dispatch","width":1},
                                        {"arrows":"to","from":"Dispatch","label":"Notifies","to":"FirstResponder","width":1},
                                        {"arrows":"to","from":"FireTruck","label":"Carries","to":"FirstResponder","width":1},
                                        {"arrows":"to","from":"FireTruck","label":"ConnectsTo","to":"Hydrant","width":1},
                                        {"arrows":"to","from":"Hydrant","label":"Supplies","to":"Water","width":1},
                                        {"arrows":"to","from":"FirstResponder","label":"CoordinatesWith","to":"IncidentCommander","width":1},
                                        {"arrows":"to","from":"IncidentCommander","label":"Directs","to":"FirstResponder","width":1},
                                        {"arrows":"to","from":"Evacuation","label":"Involves","to":"Occupants","width":1},
                                        {"arrows":"to","from":"Occupants","label":"Follow","to":"Evacuation","width":1},
                                        {"arrows":"to","from":"CCTV","label":"Monitors","to":"Building","width":1},
                                        {"arrows":"to","from":"CCTV","label":"Provides","to":"VideoEvidence","width":1},
                                        {"arrows":"to","from":"AccessControl","label":"Restricts","to":"Entry","width":1},
                                        {"arrows":"to","from":"AccessControl","label":"Allows","to":"FirstResponder","width":1},
                                        {"arrows":"to","from":"BackupPower","label":"ActivatesDuring","to":"PowerFailure","width":1},
                                        {"arrows":"to","from":"PowerFailure","label":"Causes","to":"ITSystemsDown","width":1},
                                        {"arrows":"to","from":"ITSystemsDown","label":"Affects","to":"Communications","width":1},
                                        {"arrows":"to","from":"Smoke","label":"Causes","to":"Evacuation","width":1},
                                        {"arrows":"to","from":"Fire","label":"Damages","to":"Servers","width":1},
                                        {"arrows":"to","from":"Fire","label":"Damages","to":"Workstations","width":1},
                                        {"arrows":"to","from":"MedicalInjury","label":"Requires","to":"EMS","width":1},
                                        {"arrows":"to","from":"FirstResponder","label":"CoordinatesWith","to":"EMS","width":1},
                                        {"arrows":"to","from":"Alarm","label":"IsTriggeredBy","to":"Fire","width":1}
                                    ]);

                  nodeColors = {};
                  allNodes = nodes.get({ returnType: "Object" });
                  for (nodeId in allNodes) {
                    nodeColors[nodeId] = allNodes[nodeId].color;
                  }
                  allEdges = edges.get({ returnType: "Object" });
                  // adding nodes and edges to the graph
                  data = {nodes: nodes, edges: edges};

                  var options = {
    "configure": {
        "enabled": true,
        "filter": [
            "physics"
        ]
    },
    "edges": {
        "color": {
            "inherit": true
        },
        "smooth": {
            "enabled": true,
            "type": "dynamic"
        }
    },
    "interaction": {
        "dragNodes": true,
        "hideEdgesOnDrag": false,
        "hideNodesOnDrag": false
    },
    "physics": {
        "enabled": true,
        "stabilization": {
            "enabled": true,
            "fit": true,
            "iterations": 1000,
            "onlyDynamicEdges": false,
            "updateInterval": 50
        }
    }
};

                  


                  
                  // if this network requires displaying the configure window,
                  // put it in its div
                  options.configure["container"] = document.getElementById("config");
                  

                  network = new vis.Network(container, data, options);

                  

                  

                  


                  

                  return network;

              }
              drawGraph();
        </script>
    </body>
</html>
